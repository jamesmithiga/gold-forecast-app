# Environment Configuration Template
# Copy this file to .env and fill in your values

# ============================================================================
# API CONFIGURATION
# ============================================================================
API_BASE_URL=http://localhost:8000
API_KEY=xgold-forecast-key-2026-3b7f8a9c2d1e5f6g
API_TIMEOUT=15
MAX_RETRIES=3
RETRY_DELAY=2

# ============================================================================
# DASHBOARD CONFIGURATION
# ============================================================================
STREAMLIT_THEME_MODE=light
STREAMLIT_CLIENT_SHOWERRORDETAILS=true

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
LOG_FILE=dashboard.log
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5

# ============================================================================
# CACHING CONFIGURATION
# ============================================================================
CACHE_TYPE=memory
CACHE_TTL=3600

# Redis Configuration (optional, for production)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=your-password

# ============================================================================
# EXPORT CONFIGURATION
# ============================================================================
EXPORT_DIR=./exports
COMPRESSION_ENABLED=true

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8501
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=60

# ============================================================================
# MONITORING & LOGGING
# ============================================================================
# Sentry Configuration (optional, for production error tracking)
# SENTRY_DSN=https://your-key@sentry.io/your-project-id

# ============================================================================
# EMAIL CONFIGURATION (for alerts)
# ============================================================================
# SMTP_SERVER=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USERNAME=your-email@gmail.com
# SMTP_PASSWORD=your-password

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development
# Options: development, testing, production

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_VOLATILITY_ANALYSIS=true
ENABLE_RESIDUAL_ANALYSIS=true
ENABLE_DATA_EXPORT=true
ENABLE_BATCH_PREDICTIONS=true
ENABLE_MODEL_COMPARISON=true

# Beta Features (not in production)
ENABLE_REAL_TIME_UPDATES=false
ENABLE_BACKTESTING=false
ENABLE_ENSEMBLE_PREDICTIONS=false

# ============================================================================
# PERFORMANCE TUNING
# ============================================================================
COMPRESSION_ENABLED=true
LAZY_LOADING_ENABLED=true
BATCH_SIZE=100
WORKER_COUNT=4

# ============================================================================
# MODEL CONFIGURATION
# ============================================================================
PRIMARY_TICKER=GC=F
LSTM_LOOKBACK=60
LSTM_FORECAST_STEPS=30
PROPHET_INTERVAL_WIDTH=0.95

# ============================================================================
# DATA PROCESSING
# ============================================================================
FILL_METHOD=forward
INTERPOLATION_METHOD=linear
OUTLIER_DETECTION=true
OUTLIER_THRESHOLD=3.0

# Technical Indicators
CALCULATE_SMA=true
CALCULATE_RSI=true
CALCULATE_MACD=true
